{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Dashki Web (Next.js)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd web && npm run dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Dashki Server (Express)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd server && set PORT=8080 && npm run dev"],
      "port": 8080
    }
  ]
}
