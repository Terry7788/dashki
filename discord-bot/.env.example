# Required — bot will refuse to boot without these.

# Discord bot token from https://discord.com/developers/applications → your app → Bot → Reset Token
DISCORD_BOT_TOKEN=

# Your Discord user ID (Settings → Advanced → Developer Mode → right-click your avatar → Copy User ID).
# Only messages from this ID will be processed. Every other user is silently ignored.
DISCORD_ALLOWED_USER_ID=

# Optional. Channel ID the bot listens in (right-click the channel → Copy Channel ID,
# requires Developer Mode). When set, the bot processes messages from this channel
# plus DMs. When blank, DMs only (the original behaviour).
DISCORD_ALLOWED_CHANNEL_ID=

# URL of YOUR Dashki API instance (NOT Dashki-Teela).
# Local dev:  http://localhost:4001
# Production: https://<your-dashki-server>.railway.app
DASHKI_API_URL=

# OpenAI key — used by the bot's message handler to call the parse-foods + estimate-nutrition endpoints.
# Optional for the scaffold ticket (DSHKI-26); required from DSHKI-29 onwards.
OPENAI_API_KEY=
